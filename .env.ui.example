# Copy to `.env.ui` and align credentials with the target Frappe site.
# UI_ADMIN_PASSWORD must match Administrator on UI_BASE_URL.
# Role emails / Test@123 match kentender_core.seeds.constants after seed_core_minimal.
# Auditor lines are optional — core seed does not create that user yet (see tests/ui/README.md).
UI_BASE_URL=http://127.0.0.1:8000
UI_ADMIN_USER=Administrator
UI_ADMIN_PASSWORD=admin
UI_STRATEGY_USER=strategy.manager@moh.test
UI_STRATEGY_PASSWORD=Test@123
UI_PLANNING_USER=planning.authority@moh.test
UI_PLANNING_PASSWORD=Test@123
UI_REQUISITIONER_USER=requisitioner@moh.test
UI_REQUISITIONER_PASSWORD=Test@123
UI_PLANNER_USER=planner@moh.test
UI_PLANNER_PASSWORD=Test@123
UI_PROCUREMENT_OFFICER_USER=procurement.officer@moh.test
UI_PROCUREMENT_OFFICER_PASSWORD=Test@123
UI_AUDITOR_USER=auditor@moh.test
UI_AUDITOR_PASSWORD=Test@123
UI_HOD_USER=hod.approver@moh.test
UI_HOD_PASSWORD=Test@123
UI_FINANCE_USER=finance.reviewer@moh.test
UI_FINANCE_PASSWORD=Test@123
