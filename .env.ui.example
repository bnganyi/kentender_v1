# Copy to `.env.ui` and align credentials with the target Frappe site.
# `npm run test:ui:smoke` uses Administrator by default; UI_ADMIN_PASSWORD must match that user on UI_BASE_URL.
UI_BASE_URL=http://127.0.0.1:8000
UI_ADMIN_USER=Administrator
UI_ADMIN_PASSWORD=admin
UI_STRATEGY_USER=strategy.manager@example.com
UI_STRATEGY_PASSWORD=secret
UI_PLANNING_USER=planning.authority@example.com
UI_PLANNING_PASSWORD=secret
