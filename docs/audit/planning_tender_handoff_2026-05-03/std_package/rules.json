        ],
        "validate": []
      },
      "message": "International tendering activates foreign tenderer local input configuration and form requirements.",
      "affected_sections": ["TDS", "TENDERING_FORMS"],
      "affected_fields": ["METHOD.TENDER_SCOPE", "PARTICIPATION.FOREIGN_TENDERER_LOCAL_INPUT_RULE_APPLICABLE"],
