      "description": "A tender cannot be generated without core tender identity information.",
      "enabled": true,
      "severity": "BLOCKER",
      "when": { "all": [] },
      "then": {
        "require_fields": [
          "TENDER.PROCURING_ENTITY_NAME",
          "TENDER.PROCURING_ENTITY_ADDRESS",
          "TENDER.PROCURING_ENTITY_EMAIL",
          "TENDER.TENDER_NAME",
          "TENDER.TENDER_REFERENCE",
          "TENDER.CONTRACT_DESCRIPTION",
          "TENDER.WORKS_LOCATION",
          "TENDER.ESTIMATED_COST"
